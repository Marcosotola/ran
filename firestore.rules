rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function isAdmin() {
      return hasRole('admin');
    }

    function isSubscriptionActive() {
      return get(/databases/$(database)/documents/settings/app).data.subscription.status == 'active';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isSubscriptionActive() && (hasRole('contenido') || isAdmin());
    }

    // Quotes collection
    match /quotes/{quoteId} {
      allow read: if isAuthenticated(); // Vendors and admins can see quotes
      allow create: if true; // Clients can create quotes via AI chat
      allow update: if isSubscriptionActive() && (hasRole('vendedor') || isAdmin());
    }

    // Sales collection
    match /sales/{saleId} {
      allow read: if isAuthenticated() && (hasRole('secretaria') || hasRole('finanzas') || isAdmin());
      allow write: if isSubscriptionActive() && (hasRole('secretaria') || hasRole('vendedor') || isAdmin());
    }

    // Expenses collection
    match /expenses/{expenseId} {
      allow read, write: if isSubscriptionActive() && (hasRole('finanzas') || isAdmin());
    }

    // Settings
    match /settings/app {
      allow read: if true;
      allow write: if request.auth.uid == 'NEXT_PUBLIC_DEV_UID_PLACEHOLDER'; // Only the dev can change the subscription status manually via rules or dev panel
    }
  }
}
